{
  "name": "gene-set-codex-demo",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "containerEnv": {
    "GENE_SET_MCP_URL": "https://translator.broadinstitute.org/genetics_provider/mcp_geneset/mcp",
    "GENE_SET_MCP_BEARER_TOKEN": "change-me"
  },
  "postCreateCommand": "bash ./setup-demo.sh --skip-install",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
